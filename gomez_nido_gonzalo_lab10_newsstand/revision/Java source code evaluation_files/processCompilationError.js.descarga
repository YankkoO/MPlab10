function processCompilationError(compilationError) {
    let div = '<div class="d-flex flex-column align-items-center justify-content-center">';
    div += '<div class="w-100 d-flex justify-content-between align-items-start p-3 h4 pb-2 mb-4 border-bottom border-3 border-danger">';
    div += '<a class="link-danger link-offset-2 link-underline-opacity-0 link-underline-opacity-25-hover" data-bs-toggle="collapse" href="#compilationError" role="button" aria-expanded="false" aria-controls="compilationError">' + compilationError['title'] + "</a>";
    div += '<span class="badge text-bg-danger rounded-pill">' + compilationError['lines'].length + '</span>';
    div += '</div>';
    div += '<div class="w-100 collapse" id="compilationError"><div class="rule-results d-flex align-items-start flex-column ">';
    div += '<div class="w-100 border border-2 border-dark-subtle p-2 rounded card-body">' + compilationError['description'] + '</div>'
    let lines = compilationError['lines'];
    for (let i = 0; i < lines.length; i++) {
        div += '<div class="mt-2 d-flex">';
        div += '<div class="bg-danger bg-opacity-25 border border-danger border-2 p-2 rounded me-1">' + (i + 1) + '</div>';
        div += '<a class="btn btn-danger" data-bs-toggle="collapse" href="#compilationError' + i + '" role="button" aria-expanded="false" aria-controls="compilationError' + i + '">' + lines[i]['location'] + '</a>';
        div += '</div>';
        div += '<div class="collapse mt-2 p-2 ms-2 mb-4" id="compilationError' + i + '"><div class="d-flex flex-column">'
        if (lines[i].code) {
            div += '<div class="file-tab p-2">' + lines[i]['location'].split(' ')[0].split('\\').pop() + '</div>'
            div += lines[i].code;
        }
        div += '<div class="mt-2">' + lines[i].message + '</div></div></div>';
    }
    div += '</div></div></div>';
    $('#results').append(div);

    document.querySelectorAll('.collapse').forEach(element => {
        element.addEventListener('shown.bs.collapse', () => {
            window.dispatchEvent(new Event('resize'));
        });
    });
    Prism.highlightAll();

    const toastBootstrap = bootstrap.Toast.getOrCreateInstance(document.getElementById('compilation-error-toast'));
    toastBootstrap.show();
}